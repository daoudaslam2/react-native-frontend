<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_prayer_large_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:paddingStart="28dp"
    android:paddingTop="28dp"
    android:paddingEnd="28dp"
    android:paddingBottom="28dp">

    <ImageView
        android:id="@+id/widget_large_ring_solid"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-44dp"
        android:layout_marginEnd="-62dp"
        android:background="@drawable/widget_large_ring"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/widget_large_ring_dotted"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-74dp"
        android:background="@drawable/widget_large_dotted_ring"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/widget_large_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:text="Tuesday, 12 Sep"
        android:textColor="@color/widget_muted"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widget_large_time_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_large_date"
        android:layout_marginTop="18dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_large_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="14:30"
            android:textColor="@color/widget_text"
            android:textSize="46sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_large_seconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:includeFontPadding="false"
            android:text=": 45"
            android:textColor="@color/widget_primary"
            android:textSize="36sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_large_more"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="@drawable/widget_more_circle"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="•••"
        android:textColor="@color/widget_muted"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widget_large_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_large_time_row"
        android:layout_marginTop="48dp"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/widget_large_dhuhr_row"
            android:layout_width="match_parent"
            android:layout_height="54dp">

            <ImageView
                android:id="@+id/widget_large_dhuhr_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:src="@drawable/ic_namaz_dhuhr"
                android:tint="@color/widget_inactive" />

            <TextView
                android:id="@+id/widget_large_dhuhr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="46dp"
                android:layout_toEndOf="@id/widget_large_dhuhr_icon"
                android:includeFontPadding="false"
                android:text="Dhuhr"
                android:textColor="@color/widget_inactive"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/widget_large_dhuhr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:includeFontPadding="false"
                android:text="13:15"
                android:textColor="@color/widget_inactive"
                android:textSize="22sp" />
        </RelativeLayout>

        <FrameLayout
            android:id="@+id/widget_large_current_row"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/widget_card_current_bg">

            <TextView
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@drawable/widget_current_left_accent" />

            <FrameLayout
                android:id="@+id/widget_large_current_icon_bg"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="24dp"
                android:background="@drawable/widget_green_circle"
                android:padding="14dp">

                <ImageView
                    android:id="@+id/widget_large_current_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_namaz_asr" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/widget_large_current_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="112dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_large_current_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Asr"
                    android:textColor="@color/widget_text"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_large_current_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:includeFontPadding="false"
                    android:text="In 1h 45m"
                    android:textColor="@color/widget_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_large_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="24dp"
                android:includeFontPadding="false"
                android:text="16:45"
                android:textColor="@color/widget_text"
                android:textSize="28sp"
                android:textStyle="bold" />
        </FrameLayout>

        <RelativeLayout
            android:id="@+id/widget_large_maghrib_row"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="14dp">

            <ImageView
                android:id="@+id/widget_large_maghrib_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:src="@drawable/ic_namaz_maghrib"
                android:tint="@color/widget_muted" />

            <TextView
                android:id="@+id/widget_large_maghrib_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="46dp"
                android:layout_toEndOf="@id/widget_large_maghrib_icon"
                android:includeFontPadding="false"
                android:text="Maghrib"
                android:textColor="@color/widget_text"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/widget_large_maghrib_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:includeFontPadding="false"
                android:text="19:32"
                android:textColor="@color/widget_muted"
                android:textSize="24sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="84dp"
                android:background="@drawable/widget_row_divider" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/widget_large_isha_row"
            android:layout_width="match_parent"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/widget_large_isha_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:src="@drawable/ic_namaz_isha"
                android:tint="@color/widget_muted" />

            <TextView
                android:id="@+id/widget_large_isha_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="46dp"
                android:layout_toEndOf="@id/widget_large_isha_icon"
                android:includeFontPadding="false"
                android:text="Isha"
                android:textColor="@color/widget_text"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/widget_large_isha_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:includeFontPadding="false"
                android:text="21:05"
                android:textColor="@color/widget_muted"
                android:textSize="24sp" />
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
