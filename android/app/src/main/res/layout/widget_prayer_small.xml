<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_prayer_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg">

    <ImageView
        android:id="@+id/widget_small_ring"
        android:layout_width="98dp"
        android:layout_height="98dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:src="@drawable/widget_small_corner_ring"
        android:contentDescription="@null" />

    <FrameLayout
        android:id="@+id/widget_small_icon_bg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/widget_green_circle"
        android:padding="6dp">

        <ImageView
            android:id="@+id/widget_small_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:src="@drawable/ic_namaz_asr" />
    </FrameLayout>

    <TextView
        android:id="@+id/widget_small_current_prayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="18dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@id/widget_small_icon_bg"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:singleLine="true"
        android:text="Asr"
        android:textColor="@color/widget_text"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_small_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_small_current_prayer"
        android:layout_alignStart="@id/widget_small_current_prayer"
        android:layout_marginTop="10dp"
        android:includeFontPadding="false"
        android:text="1h 45m remaining"
        android:textColor="@color/widget_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widget_small_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_small_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Next: Maghrib"
            android:textColor="@color/widget_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/widget_small_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:max="1000"
            android:progress="680"
            android:progressDrawable="@drawable/widget_progress_bar" />
    </LinearLayout>
</RelativeLayout>
